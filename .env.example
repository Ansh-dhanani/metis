# ============================================================
# Root .env for Docker Compose variable interpolation
# Copy to .env and fill in your values before running compose:
#   cp .env.example .env
# ============================================================

# ── MongoDB (local container or Atlas) ───────────────────────
# For local Docker MongoDB container:
# MONGO_ROOT_USER=admin
# MONGO_ROOT_PASSWORD=changeme

# For MongoDB Atlas (uncomment and update with your credentials):
MONGO_URI=mongodb+srv://ladnil03:6837@cluster0.xl7pvjm.mongodb.net/metis?retryWrites=true&w=majority

# ── Frontend public vars (baked in at image build time) ──────
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=http://localhost:5000
NEXTAUTH_URL=http://localhost:3000

# ── NextAuth Configuration ────────────────────────────────────
NEXTAUTH_SECRET=your_random_nextauth_secret_here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
